{
  "$schema": "https://www.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "isolatedDeclarations": true,
    "noCheck": true,
    "rootDir": "${configDir}",
    "outDir": "${configDir}/dist/types"
  },
  "include": ["${configDir}/src/**/*", "${configDir}/src/**/*.json"],
  "exclude": ["${configDir}/**/__tests__/**", "${configDir}/**/*.spec.*"]
}
